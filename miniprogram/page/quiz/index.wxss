page {
  width: 100vw;
  max-width: 100vw;
  min-height: 100%;
  overflow-x: hidden;
  background: #ffffff;
  color: #1f2933;
  touch-action: pan-y;
}

.quiz-page {
  width: 100vw;
  max-width: 100vw;
  min-width: 100vw;
  min-height: 100vh;
  flex: 0 0 100vw;
  overflow-x: hidden;
  box-sizing: border-box;
  background: #ffffff;
  touch-action: pan-y;
}

.app-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  background: #ffffff;
}

.app-bar-title {
  position: absolute;
  left: 40rpx;
  display: flex;
  align-items: center;
  min-width: 0;
  color: #111827;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  box-sizing: border-box;
}

.app-bar-title text {
  display: block;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.quiz-shell {
  display: flex;
  flex-direction: column;
  width: 100%;
  max-width: 100%;
  height: 100vh;
  min-height: 100vh;
  padding: 200rpx 40rpx 0;
  overflow: hidden;
  box-sizing: border-box;
  touch-action: pan-y;
}

.result-shell {
  width: 100%;
  max-width: 100%;
  min-height: 100vh;
  padding: 200rpx 32rpx 48rpx;
  overflow-x: hidden;
  box-sizing: border-box;
  background: #f8fafc;
  touch-action: pan-y;
}

.title-icon {
  position: relative;
  width: 28rpx;
  height: 22rpx;
  border: 4rpx solid #1677d2;
  border-top-width: 3rpx;
  border-radius: 3rpx;
  box-sizing: border-box;
  transform: skewY(-24deg);
}

.title-icon::before {
  content: "";
  position: absolute;
  left: -8rpx;
  top: -8rpx;
  width: 34rpx;
  height: 20rpx;
  border-top: 4rpx solid #1677d2;
  border-left: 4rpx solid #1677d2;
  transform: rotate(-22deg);
}

.bookmark-icon {
  position: relative;
  width: 24rpx;
  height: 34rpx;
  border: 4rpx solid #3b4656;
  border-bottom: 0;
  border-radius: 4rpx 4rpx 0 0;
  box-sizing: border-box;
}

.bookmark-icon::after {
  content: "";
  position: absolute;
  left: 2rpx;
  bottom: -10rpx;
  width: 12rpx;
  height: 12rpx;
  border-left: 4rpx solid #3b4656;
  border-bottom: 4rpx solid #3b4656;
  background: #ffffff;
  transform: rotate(-45deg);
}

.progress-row {
  display: flex;
  align-items: center;
  flex: 0 0 auto;
  gap: 24rpx;
  margin-top: 30rpx;
}

.progress-text {
  display: flex;
  align-items: baseline;
  flex: 0 0 auto;
  color: #64748b;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1;
  white-space: nowrap;
}

.question-total {
  color: #94a3b8;
  font-size: 28rpx;
  font-weight: 500;
}

.progress-track {
  flex: 1;
  min-width: 0;
  height: 16rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e6eaf0;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #5dbb82;
  transition: width 180ms ease;
}

.question-scroll {
  flex: 1;
  min-height: 0;
  height: 0;
}

.question-content {
  padding-bottom: 32rpx;
}

.question-text {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  margin-top: 36rpx;
  min-height: 128rpx;
  color: #1f2933;
  font-size: 38rpx;
  font-weight: 400;
  line-height: 1.55;
}

.question-copy {
  display: block;
  flex: 1;
  min-width: 0;
  overflow-wrap: break-word;
  word-break: break-word;
}

.question-analysis {
  flex: 0 0 auto;
  margin: 0 0 22rpx;
  padding: 22rpx 24rpx;
  border-radius: 12rpx;
  color: #1f2933;
  box-sizing: border-box;
  animation: explanationIn 140ms ease-out;
}

.question-analysis-correct {
  border-left: 6rpx solid #5dbb82;
  background: #f1fbf5;
}

.question-analysis-wrong {
  border-left: 6rpx solid #e06454;
  background: #fff4f1;
}

.analysis-heading {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 16rpx;
  margin-top: 12rpx;
}

.analysis-answer {
  color: #111827;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.25;
}

.analysis-title {
  color: #2f7d54;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.2;
}

.question-analysis-wrong .analysis-title {
  color: #b23b31;
}

.analysis-copy {
  display: -webkit-box;
  max-height: 156rpx;
  margin-top: 10rpx;
  overflow: hidden;
  color: #475569;
  font-size: 26rpx;
  line-height: 1.5;
  overflow-wrap: break-word;
  word-break: break-word;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
}

.answer-dock {
  flex: 0 0 auto;
  margin: 0 -40rpx;
  padding: 22rpx 40rpx calc(24rpx + env(safe-area-inset-bottom));
  border-top: 2rpx solid #edf0f4;
  background: #ffffff;
  box-sizing: border-box;
}

.option-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
  max-width: 100%;
  box-sizing: border-box;
}

.option {
  display: flex;
  align-items: center;
  width: 100%;
  max-width: 100%;
  min-height: 104rpx;
  padding: 22rpx 30rpx;
  border: 2rpx solid #c5cfdf;
  border-radius: 12rpx;
  background: #ffffff;
  color: #1f2933;
  font-size: 28rpx;
  font-weight: 400;
  line-height: 1.35;
  text-align: left;
  box-sizing: border-box;
}

.primary-button::after,
.ghost-button::after,
.restart-button::after {
  border: 0;
}

.option-selected {
  border-color: #62b981;
  background: #eef9f2;
}

.option-correct {
  border-color: #62b981;
  background: #e6f6ed;
}

.option-wrong {
  border-color: #e06454;
  background: #fff1ee;
}

.option-code {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  width: 60rpx;
  height: 60rpx;
  margin-right: 34rpx;
  border: 2rpx solid #cbd5e1;
  border-radius: 50%;
  color: #111827;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1;
  box-sizing: border-box;
}

.option-selected .option-code,
.option-correct .option-code {
  border-color: #62b981;
  color: #2f7d54;
}

.option-wrong .option-code {
  border-color: #e06454;
  color: #b23b31;
}

.option-body {
  flex: 1;
  min-width: 0;
}

.option-text {
  display: block;
  overflow-wrap: break-word;
  word-break: break-word;
}

.option-tail {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  max-width: 152rpx;
  margin-left: 18rpx;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.2;
  text-align: center;
  box-sizing: border-box;
}

.option-tail-correct {
  background: #dff4e8;
  color: #2f7d54;
}

.option-tail-wrong {
  background: #ffe2dc;
  color: #b23b31;
}

@keyframes explanationIn {
  from {
    opacity: 0;
    transform: translateY(-6rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.action-row {
  display: flex;
  gap: 36rpx;
  width: 100%;
  max-width: 100%;
  margin-top: 24rpx;
  box-sizing: border-box;
}

.ghost-button,
.primary-button {
  flex: 1;
  min-height: 90rpx;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: 400;
  line-height: 90rpx;
}

.ghost-button {
  background: #eeeeef;
  color: #111827;
}

.ghost-button[disabled] {
  color: #98a2b3;
  opacity: 1;
}

.primary-button {
  background: #5dbb82;
  color: #ffffff;
}

.result-hero {
  margin-top: 8rpx;
  padding: 44rpx 28rpx;
  border-radius: 16rpx;
  background: #ffffff;
  color: #111827;
  text-align: center;
}

.result-label {
  color: #64748b;
  font-size: 26rpx;
  font-weight: 600;
}

.result-score {
  margin-top: 8rpx;
  color: #1677d2;
  font-size: 112rpx;
  font-weight: 800;
  line-height: 1;
}

.result-copy {
  margin-top: 16rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.best-line {
  margin-top: 12rpx;
  color: #64748b;
  font-size: 24rpx;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 24rpx;
}

.summary-item {
  padding: 22rpx 8rpx;
  border-radius: 12rpx;
  background: #ffffff;
  text-align: center;
}

.summary-value {
  display: block;
  color: #111827;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1;
}

.summary-label {
  display: block;
  margin-top: 8rpx;
  color: #64748b;
  font-size: 22rpx;
}

.review-list {
  display: grid;
  gap: 18rpx;
  margin-top: 26rpx;
}

.review-item {
  padding: 24rpx;
  border-radius: 12rpx;
  background: #ffffff;
}

.review-right {
  border-left: 8rpx solid #62b981;
}

.review-wrong {
  border-left: 8rpx solid #e06454;
}

.review-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.review-number {
  color: #111827;
  font-size: 24rpx;
  font-weight: 800;
}

.review-status {
  color: #64748b;
  font-size: 22rpx;
  font-weight: 600;
}

.review-question {
  margin-top: 16rpx;
  color: #111827;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
}

.review-answer,
.review-explain {
  margin-top: 10rpx;
  color: #475569;
  font-size: 24rpx;
  line-height: 1.45;
}

.restart-button {
  width: 100%;
  margin-top: 28rpx;
}

.modal-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 60;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: rgba(17, 24, 39, 0.46);
  box-sizing: border-box;
  animation: maskIn 140ms ease-out both;
}

.submit-dialog {
  position: relative;
  width: 100%;
  max-width: 620rpx;
  padding: 42rpx 30rpx 28rpx;
  border-radius: 18rpx;
  background: #ffffff;
  box-shadow: 0 28rpx 90rpx rgba(17, 24, 39, 0.22);
  box-sizing: border-box;
  animation: dialogIn 160ms ease-out both;
}

.dialog-close {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #f6f7f9;
  color: #6b7280;
  font-size: 34rpx;
  font-weight: 400;
  line-height: 44rpx;
}

.dialog-header {
  display: flex;
  gap: 20rpx;
  padding-right: 46rpx;
}

.dialog-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: #fff2d8;
  color: #b05a00;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1;
}

.dialog-text {
  flex: 1;
  min-width: 0;
}

.dialog-title {
  color: #111827;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.35;
}

.dialog-copy {
  margin-top: 12rpx;
  color: #4b5563;
  font-size: 26rpx;
  line-height: 1.6;
}

.dialog-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 30rpx;
}

.dialog-secondary,
.dialog-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  min-width: 0;
  height: 76rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
  text-align: center;
  box-sizing: border-box;
}

.dialog-secondary {
  border: 2rpx solid #d1d5db;
  background: #f9fafb;
  color: #111827;
}

.dialog-primary {
  background: #d94832;
  color: #ffffff;
}

@keyframes maskIn {
  from {
    opacity: 0;
  }

  to {
    opacity: 1;
  }
}

@keyframes dialogIn {
  from {
    opacity: 0;
    transform: translateY(16rpx) scale(0.98);
  }

  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}
