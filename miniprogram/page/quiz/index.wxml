<view class="quiz-page" bindtouchstart="handleTouchStart" bindtouchend="handleTouchEnd" bindtouchcancel="handleTouchCancel">
  <view class="app-bar" style="height: {{appBarHeight}}px;">
    <view
      class="app-bar-back"
      style="top: {{menuButtonTop}}px; height: {{menuButtonHeight}}px;"
      bindtap="handleBackTap"
      aria-role="button"
      aria-label="返回"
    >
      <view class="app-bar-back__icon"></view>
    </view>
    <view
      class="app-bar-title"
      style="top: {{menuButtonTop}}px; height: {{menuButtonHeight}}px; right: {{appBarTitleRight}}px;"
    >
      <text>{{quizTitle}}</text>
    </view>
  </view>

  <view wx:if="{{!isCompleted && currentQuestion}}" class="quiz-shell" style="padding-top: {{contentTop}}px;">
    <view class="progress-row">
      <view class="progress-text">
        <text class="question-count">{{currentNumber}}</text>
        <text class="question-total">/{{total}}</text>
      </view>
      <view class="progress-track">
        <view class="progress-fill" style="width: {{progressPercent}}%;"></view>
      </view>
      <view wx:if="{{isTestMode}}" class="timer-pill {{timerSeconds <= 60 ? 'timer-pill-warning' : ''}}">
        {{timerText}}
      </view>
      <icon-action-button
        icon="/image/icons/apps.png"
        action="overview"
        label="打开试卷全览"
        variant="panel"
        bindactiontap="handleIconAction"
      />
    </view>

    <scroll-view
      class="question-scroll"
      scroll-y="{{isQuestionScrollable}}"
      scroll-top="{{questionScrollTop}}"
      enhanced="{{true}}"
      show-scrollbar="{{false}}"
    >
      <view class="question-content">
        <view wx:if="{{currentQuestion.isMultiple}}" class="question-type-badge">多选</view>
        <view class="question-text">
          <icon-action-button
            icon="{{isCurrentQuestionFavorite ? '/image/icons/star.png' : '/image/icons/not_star.png'}}"
            action="favorite"
            label="{{isCurrentQuestionFavorite ? '取消收藏本题' : '收藏本题'}}"
            variant="question"
            active="{{isCurrentQuestionFavorite}}"
            bindactiontap="handleIconAction"
          />
          <text class="question-copy">{{currentQuestion.prompt}}</text>
        </view>
      </view>
    </scroll-view>

    <view wx:if="{{shouldRevealAnswer}}" class="question-analysis {{questionAnalysisClass}}">
      <view class="analysis-answer">正确答案: {{currentCorrectAnswerCode}}</view>
      <view class="analysis-heading">
        <view class="analysis-title">题目解析</view>
      </view>
      <text class="analysis-copy">{{currentExplanation}}</text>
    </view>

    <view class="answer-dock">
      <view class="option-list">
        <block wx:for="{{currentQuestion.options}}" wx:for-item="option" wx:for-index="optionIndex" wx:key="*this">
          <view
            class="option {{option.isSelected ? 'option-selected' : ''}} {{shouldRevealAnswer && option.isCorrect ? 'option-correct' : ''}} {{hasAnswered && option.isWrongSelected ? 'option-wrong' : ''}}"
            data-index="{{optionIndex}}"
            data-key="{{option.key}}"
            bindtap="selectOption"
          >
            <text class="option-code">{{option.code}}</text>
            <view class="option-body">
              <text class="option-text">{{option.text}}</text>
            </view>
            <text
              wx:if="{{hasAnswered && option.isSelected}}"
              class="option-tail {{option.isCorrect ? 'option-tail-correct' : 'option-tail-wrong'}}"
            >{{option.isCorrect ? '选择正确' : '选择错误'}}</text>
            <text
              wx:elif="{{shouldRevealAnswer && option.isCorrect}}"
              class="option-tail option-tail-correct"
            >正确答案</text>
          </view>
        </block>
      </view>

      <view class="action-row">
        <button class="ghost-button" disabled="{{currentIndex === 0}}" bindtap="goPrev">上一题</button>
        <button class="primary-button" bindtap="goNext">{{primaryActionText}}</button>
      </view>
    </view>
  </view>

  <view wx:elif="{{!isCompleted}}" class="empty-shell" style="padding-top: {{contentTop}}px;">
    <view class="empty-title">暂无题目</view>
    <button class="primary-button empty-button" bindtap="handleReturnHome">返回首页</button>
  </view>

  <view wx:else class="result-shell" style="padding-top: {{contentTop}}px;">
    <view class="result-hero">
      <view class="result-label">本次成绩</view>
      <view class="result-score">{{score}}</view>
      <view class="result-copy">答对 {{correctCount}} / {{total}} 题</view>
      <view class="best-line">历史最佳：{{bestScore}} 分</view>
    </view>

    <view class="summary-grid">
      <view class="summary-item">
        <text class="summary-value">{{correctCount}}</text>
        <text class="summary-label">正确</text>
      </view>
      <view class="summary-item">
        <text class="summary-value">{{total - correctCount}}</text>
        <text class="summary-label">错误</text>
      </view>
      <view class="summary-item">
        <text class="summary-value">{{score}}</text>
        <text class="summary-label">分数</text>
      </view>
    </view>

    <view class="result-actions">
      <button class="ghost-button" bindtap="resetQuiz">再来一次</button>
      <button class="primary-button" bindtap="handleReturnHome">返回首页</button>
    </view>

    <view class="review-list">
      <block wx:for="{{resultItems}}" wx:key="id">
        <view class="review-item {{item.isCorrect ? 'review-right' : 'review-wrong'}}">
          <view class="review-top">
            <text class="review-number">Q{{item.number}}</text>
            <text class="review-status">{{item.isCorrect ? '正确' : '待复习'}}</text>
          </view>
          <view class="review-question">{{item.prompt}}</view>
          <view class="review-answer">你的答案：{{item.selectedAnswer}} ｜ 正确答案：{{item.correctAnswer}}</view>
          <view class="review-explain">{{item.explanation}}</view>
        </view>
      </block>
    </view>
  </view>

  <view wx:if="{{showSubmitModal}}" class="modal-mask" catchtouchmove="noop" catchtap="closeSubmitModal">
    <view class="submit-dialog" catchtap="noop">
      <view class="dialog-close" bindtap="closeSubmitModal" aria-role="button" aria-label="关闭弹窗">×</view>
      <view class="dialog-header">
        <view class="dialog-mark">!</view>
        <view class="dialog-text">
          <view class="dialog-title">还有题目没答完</view>
          <view class="dialog-copy">当前还有 {{unansweredCount}} 道题未作答，提交后未作答题目会按错误计入成绩。</view>
        </view>
      </view>
      <view class="dialog-actions">
        <view class="dialog-secondary" bindtap="openPaperOverview" aria-role="button">试卷全览</view>
        <view class="dialog-primary" bindtap="forceSubmitQuiz" aria-role="button">我就要交,你少管</view>
      </view>
    </view>
  </view>

  <question-overview-sheet
    visible="{{showQuestionOverview}}"
    total="{{total}}"
    answered-count="{{total - unansweredCount}}"
    items="{{overviewItems}}"
    show-status="{{showOverviewStatus}}"
    subtitle="{{overviewSubtitle}}"
    bindclose="closeQuestionOverview"
    bindselect="jumpToQuestion"
  />
</view>
