page {
  width: 100%;
  max-width: 100%;
  min-height: 100%;
  overflow-x: hidden;
  background: #f6f7fb;
  color: #172033;
}

.book-detail-page {
  width: 100%;
  max-width: 100%;
  min-width: 0;
  min-height: 100vh;
  padding-bottom: 40rpx;
  overflow-x: hidden;
  background: #f6f7fb;
  box-sizing: border-box;
}

.detail-nav {
  display: flex;
  align-items: center;
  height: 96rpx;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.detail-nav__back {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  margin-right: 14rpx;
}

.detail-nav__back-icon {
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid #111827;
  border-bottom: 4rpx solid #111827;
  transform: rotate(45deg);
}

.detail-nav__title {
  color: #111827;
  font-size: 32rpx;
  font-weight: 500;
  line-height: 1;
}

.detail-content {
  padding: 18rpx 32rpx 0;
  box-sizing: border-box;
}

.section-title {
  margin-top: 48rpx;
  color: #273244;
  font-size: 32rpx;
  font-weight: 500;
  line-height: 1.2;
}

.chapter-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  margin-top: 28rpx;
}

.config-sheet {
  padding-bottom: 4rpx;
}

.config-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.config-heading {
  flex: 1;
  min-width: 0;
}

.config-title {
  color: #111827;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.25;
}

.config-description {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 25rpx;
  font-weight: 600;
  line-height: 1.35;
}

.config-close {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: #f3f4f6;
  color: #6b7280;
  font-size: 38rpx;
  line-height: 54rpx;
}

.config-section {
  margin-top: 34rpx;
}

.config-section-title {
  color: #1f2937;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.2;
}

.config-chip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 18rpx;
}

.config-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 132rpx;
  height: 66rpx;
  padding: 0 24rpx;
  border: 2rpx solid #d8e0ea;
  border-radius: 999rpx;
  background: #ffffff;
  color: #263040;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1;
  box-sizing: border-box;
}

.config-chip--active {
  border-color: #1677d2;
  background: #eaf3ff;
  color: #1457c5;
  box-shadow: 0 0 0 5rpx rgba(22, 119, 210, 0.12);
}

.config-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 38rpx;
}

.config-secondary,
.config-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  min-width: 0;
  height: 82rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1;
  text-align: center;
  box-sizing: border-box;
}

.config-secondary {
  border: 2rpx solid #d1d5db;
  background: #f9fafb;
  color: #111827;
}

.config-primary {
  background: #1677d2;
  color: #ffffff;
}
