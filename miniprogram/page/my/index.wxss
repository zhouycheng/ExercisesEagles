page {
  width: 100%;
  max-width: 100%;
  min-height: 100%;
  overflow-x: hidden;
  background: #ffffff;
  color: #111827;
}

.my-page {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  max-width: 100%;
  min-width: 0;
  min-height: 100vh;
  padding-bottom: 120rpx;
  overflow-x: hidden;
  background: #ffffff;
  box-sizing: border-box;
}

.my-placeholder {
  color: #374151;
  font-size: 34rpx;
  font-weight: 500;
}
