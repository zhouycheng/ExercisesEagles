page {
  width: 100%;
  max-width: 100%;
  min-height: 100%;
  overflow-x: hidden;
  background: #ffffff;
  color: #0f172a;
}

.home-page {
  width: 100%;
  max-width: 100%;
  min-width: 0;
  min-height: 100vh;
  padding: 0 36rpx 150rpx;
  overflow-x: hidden;
  background: #ffffff;
  box-sizing: border-box;
}

.home-header {
  display: flex;
  align-items: center;
  height: 104rpx;
  color: #111827;
  font-size: 40rpx;
  font-weight: 400;
  line-height: 1;
}

.book-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  width: 100%;
  box-sizing: border-box;
}

.book-grid__item {
  display: flex;
  justify-content: center;
  width: calc((100% - 34rpx) / 2);
  min-width: 0;
  margin-bottom: 52rpx;
  box-sizing: border-box;
}
