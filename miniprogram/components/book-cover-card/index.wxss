.book-cover-card {
  width: 100%;
  min-width: 0;
  box-sizing: border-box;
}

.book-cover-card__cover {
  display: block;
  position: relative;
  width: 100%;
  height: 0;
  padding-bottom: 141%;
  overflow: hidden;
  border-radius: 6rpx;
  background: #eef2f7;
  box-sizing: border-box;
}

.book-cover-card__cover--hover {
  opacity: 0.86;
}

.book-cover-card__image {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: block;
  width: 100%;
  height: 100%;
}

.book-cover-card__title {
  display: block;
  margin-top: 14rpx;
  color: #0f172a;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.18;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
